  "spellcheckLanguages": [
    "es-PE",
    "en-US"
  ],
  "showInlineTitle": true,
  "showLineStatusInEditor": true,
  "showRibbon": true,
  "alwaysPromptForNewFolderNaming": false,
  "newLinkFormat": "short",
  "useMarkdownLinks": false,
  "showUnsupportedFiles": true,
